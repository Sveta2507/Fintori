{
  "name": "fintori",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "build:watch": "node build.mjs --watch",
    "test:jest": "jest --config tests/configs/jest.config.cjs",
    "test:jest:watch": "jest --config tests/configs/jest.config.cjs --watch",
    "test:jest:coverage": "jest --config tests/configs/jest.config.cjs --coverage",
    "test:vitest": "vitest run --config tests/configs/vitest.config.js",
    "test:vitest:watch": "vitest --config tests/configs/vitest.config.js",
    "test:e2e": "playwright test --config tests/configs/playwright.config.js"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@playwright/test": "^1.44.0",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "javascript-obfuscator": "^4.1.1",
    "vitest": "^1.6.0"
  }
}
